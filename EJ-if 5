#include <iostream>
using namespace std;
int main()
{
    int puntos = 0;
    int opcion;

    cout << "----SISTEMA DE PUNTOS----" << endl;
    cout << "1. Ganar partida (+10 puntos)" << endl;
    cout << "2. Perder partida (-5 puntos)" << endl;
    cout << "3. Bonus (+20 puntos)" << endl;
    cout << "Elige una opcion: ";
    cin >> opcion;
    cout << "   Opcion (1-3): " << opcion << endl;

    switch (opcion) {
        case 1:
            puntos += 10;
            cout << "Ganaste 10 puntos ";
            break;

        case 2:
            puntos -= 5;
            cout << "Perdiste 5 puntos ";
            break;

        case 3:
            puntos += 20;
            cout << "Ganaste bonus de 20 puntos ";
            break;
        default:
            cout << "Opcion invalida ";
    }

}
